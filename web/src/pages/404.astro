---
import Layout from '../layouts/Layout.astro';
---
<Layout title="페이지를 찾을 수 없어요 — 연구 아카이브" description="요청하신 페이지가 없습니다." noindex={true}>
  <main class="wrap" style="padding:100px 20px;text-align:center">
    <div style="font-size:52px;font-weight:700;color:var(--ink-3)">404</div>
    <p style="font-size:15px;color:var(--ink-2);margin:14px 0 28px">페이지를 찾을 수 없어요. 주소가 바뀌었거나 삭제된 페이지예요.</p>
    <a href="/" class="primary-btn" style="text-decoration:none">홈으로 가기</a>
  </main>
</Layout>
