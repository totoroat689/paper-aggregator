---
import Layout from '../layouts/Layout.astro';
import AuthBar from '../components/AuthBar.astro';
import { supabase, STUDY_TYPE_LABELS, CATEGORY_KO, categoryKo, fieldColor, countryName } from '../lib/supabase.js';

Astro.response.headers.set('Cache-Control', 'public, s-maxage=120, stale-while-revalidate=600');

const params = Astro.url.searchParams;

// 정렬 (기본 = 추천순)
const sortParam = params.get('sort');
const sort = sortParam === 'cited' ? 'cited' : sortParam === 'recent' ? 'recent' : 'reco';

// 대분류(연구유형) — 쉼표로 여러 개 선택 가능
const TYPE_MAP = {
  meta_analysis: ['meta_analysis'],
  experiment: ['rct', 'experimental_likely'],
  observational: ['observational'],
  review: ['review'],
  etc: ['other', 'unclassified'],
};
const types = (params.get('type') || '').split(',').map((s) => s.trim()).filter((k) => TYPE_MAP[k]);

// 소분류(분야) — 쉼표로 여러 개 선택 가능 (한글 분야명 기준)
const KO_TO_EN = {};
for (const [en, ko] of Object.entries(CATEGORY_KO)) {
  (KO_TO_EN[ko] = KO_TO_EN[ko] || []).push(en);
}
const catOptions = Object.keys(KO_TO_EN).sort((a, b) => a.localeCompare(b, 'ko'));
const cats = (params.get('cat') || '').split(',').map((s) => s.trim()).filter((s) => KO_TO_EN[s]);

// 검색어
const q = (params.get('q') || '').trim();

// 한글 검색어면 캐시된 확장 용어(영어) 사용
const hasKorean = /[가-힣]/.test(q);
let searchTerms = q ? [q] : [];
if (q && hasKorean) {
  const { data: exp } = await supabase
    .from('search_expansions')
    .select('terms')
    .eq('query', q)
    .single();
  if (exp?.terms?.length) {
    searchTerms = [q, ...exp.terms];
  }
}

// 페이지
const PER_PAGE = 30;
const pageParam = parseInt(params.get('page') || '1', 10);
const page = Number.isNaN(pageParam) || pageParam < 1 ? 1 : pageParam;
const from = (page - 1) * PER_PAGE;
const to = from + PER_PAGE - 1;

// 쿼리 빌드 (전체 데이터 대상)
let query = supabase
  .from('papers')
  .select('id, title_en, title_ko, abstract_en, abstract_ko, study_type, primary_category, citation_count, view_count, publication_year, publication_date, countries, is_retracted', { count: 'exact' })
  .eq('is_retracted', false);

if (types.length > 0) {
  query = query.in('study_type', types.flatMap((k) => TYPE_MAP[k]));
}
if (cats.length > 0) {
  query = query.in('primary_category', cats.flatMap((c) => KO_TO_EN[c]));
}
if (q) {
  const conds = searchTerms.flatMap((t) => [
    `title_ko.ilike.%${t}%`,
    `title_en.ilike.%${t}%`,
    `abstract_en.ilike.%${t}%`,
  ]);
  query = query.or(conds.join(','));
}

let papers, error, count;
if (sort === 'reco' && from < 300) {
  // 추천순: 최근 논문 풀(최대 300건)을 [최신성 45% + 인용 35% + 조회수 20%] 점수로 재정렬
  const res = await query
    .order('publication_date', { ascending: false, nullsFirst: false })
    .range(0, 299);
  error = res.error;
  count = res.count;
  const pool = res.data || [];
  const now = Date.now();
  const maxC = Math.max(1, ...pool.map((p) => p.citation_count || 0));
  const maxV = Math.max(1, ...pool.map((p) => p.view_count || 0));
  const score = (p) => {
    const days = p.publication_date
      ? Math.max(0, (now - new Date(p.publication_date).getTime()) / 86400000)
      : 365;
    const fresh = Math.exp(-days / 45); // 45일 단위로 절반씩 감쇠
    const cite = Math.log10(1 + (p.citation_count || 0)) / Math.log10(1 + maxC);
    const view = Math.log10(1 + (p.view_count || 0)) / Math.log10(1 + maxV);
    return 0.45 * fresh + 0.35 * cite + 0.2 * view;
  };
  pool.sort((a, b) => score(b) - score(a));
  papers = pool.slice(from, from + PER_PAGE);
} else {
  // 최신순/인용순 (추천순의 뒷페이지도 최신순으로 이어짐)
  const orderCol = sort === 'cited' ? 'citation_count' : 'publication_date';
  const res = await query
    .order(orderCol, { ascending: false, nullsFirst: false })
    .range(from, to);
  papers = res.data;
  error = res.error;
  count = res.count;
}

const list = papers || [];
const total = count || 0;
const totalPages = Math.max(1, Math.ceil(total / PER_PAGE));

function studyInfo(t) { return STUDY_TYPE_LABELS[t] || STUDY_TYPE_LABELS.unclassified; }
function shortAbstract(p) {
  const t = p.abstract_ko || p.abstract_en;
  if (!t) return '초록이 제공되지 않는 논문입니다.';
  return t.length > 300 ? t.slice(0, 300) + '…' : t;
}
// 발표일 예쁘게: 2024-03-15 -> 2024.03.15 (일자 없으면 연도만)
function fmtDate(p) {
  if (p.publication_date) {
    const parts = String(p.publication_date).split('-');
    if (parts.length === 3) return `${parts[0]}.${parts[1]}.${parts[2]}`;
    return String(p.publication_date);
  }
  if (p.publication_year && p.publication_year <= 2026) return String(p.publication_year);
  return '';
}
// 현재 조건을 유지하며 특정 값만 바꾼 URL 생성
function buildUrl(overrides = {}) {
  const p = new URLSearchParams();
  const merged = { sort, type: types.join(','), cat: cats.join(','), q, page: 1, ...overrides };
  if (merged.sort && merged.sort !== 'reco') p.set('sort', merged.sort);
  if (merged.type) p.set('type', merged.type);
  if (merged.cat) p.set('cat', merged.cat);
  if (merged.q) p.set('q', merged.q);
  if (merged.page && merged.page > 1) p.set('page', merged.page);
  const s = p.toString();
  return s ? `/?${s}` : '/';
}
// 대분류(연구유형) 칩 — 여러 개 선택 가능
const chips = [
  { key: 'meta_analysis', label: '메타분석' },
  { key: 'experiment', label: '실험연구' },
  { key: 'observational', label: '관찰연구' },
  { key: 'review', label: '리뷰' },
  { key: 'etc', label: '기타·미분류' },
];
const TYPE_LABELS = Object.fromEntries(chips.map((c) => [c.key, c.label]));
const activeCount = types.length + cats.length;

// ── SEO ──
// 필터·검색·정렬이 걸린 변형 페이지는 색인 제외(무한 조합 방지), 순수 목록만 색인
const isFiltered = Boolean(q || types.length || cats.length || sort !== 'reco');
const pageTitle = q
  ? `"${q}" 검색 결과 — 연구 아카이브`
  : page > 1
    ? `최신 실증 연구 논문 ${page}페이지 — 연구 아카이브`
    : '연구 아카이브 — 전 세계 최신 실증 연구 논문을 한국어로';
const pageDesc = 'OpenAlex·Europe PMC·Semantic Scholar에서 매일 수집한 최신 실험연구·메타분석·관찰연구 논문을 분야별로 골라 보세요. 연구 신뢰도를 함께 표시합니다.';
// 검색창 구조화 데이터: 구글 검색결과에 사이트 검색창이 뜰 수 있게
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: '연구 아카이브',
  url: 'https://paper-aggregator.vercel.app',
  potentialAction: {
    '@type': 'SearchAction',
    target: { '@type': 'EntryPoint', urlTemplate: 'https://paper-aggregator.vercel.app/?q={search_term_string}' },
    'query-input': 'required name=search_term_string',
  },
};
---
<Layout
  title={pageTitle}
  description={pageDesc}
  canonical={'/' + (page > 1 && !isFiltered ? `?page=${page}` : '')}
  noindex={isFiltered}
  jsonLd={websiteJsonLd}
>
  <header class="topbar">
    <div class="wrap topbar-inner">
      <a href="/" class="brand">연구<span>아카이브</span><span class="dot"></span></a>
      <nav class="nav-links">
        <a href="/" class="on">논문</a>
        <a href="/board">게시판</a>
      </nav>
      <AuthBar />
    </div>
  </header>

  <main class="wrap">
    <div class="count-line">{q ? `"${q}" 검색: ` : ''}전체 {total.toLocaleString()}편 · {page}/{totalPages} 페이지</div>

    <div class="toolbar">
      <form class="search-box" method="get" action="/">
        <i class="ti ti-search" style="color:var(--ink-3)"></i>
        <input name="q" type="text" placeholder="제목으로 검색…" autocomplete="off" value={q} />
        {sort !== 'reco' && <input type="hidden" name="sort" value={sort} />}
        {types.length > 0 && <input type="hidden" name="type" value={types.join(',')} />}
        {cats.length > 0 && <input type="hidden" name="cat" value={cats.join(',')} />}
      </form>
      <select id="sort-select" class="tool-select" aria-label="정렬">
        <option value="reco" selected={sort === 'reco'}>추천순</option>
        <option value="recent" selected={sort === 'recent'}>최신순</option>
        <option value="cited" selected={sort === 'cited'}>인용순</option>
      </select>
      <button type="button" id="filter-toggle" class="tool-btn">
        <i class="ti ti-adjustments-horizontal"></i> 필터
        {activeCount > 0 && <span class="tool-badge">{activeCount}</span>}
      </button>
    </div>

    <div id="filter-panel" class="filter-panel" data-type={types.join(',')} hidden>
      <div class="fp-label">연구유형 — 여러 개 선택 가능</div>
      <div class="fp-chips">
        <button type="button" class={`chip fp-type type-all ${types.length === 0 ? 'on' : ''}`} data-key="all">전체</button>
        {chips.map((c) => (
          <button type="button" class={`chip fp-type type-${c.key} ${types.includes(c.key) ? 'on' : ''}`} data-key={c.key}>{c.label}</button>
        ))}
      </div>
      <div class="fp-label" style="margin-top:16px">분야 — 여러 개 선택 가능</div>
      <div class="fp-grid">
        {catOptions.map((o) => (
          <label class="fp-check"><input type="checkbox" value={o} checked={cats.includes(o)} /> {o}</label>
        ))}
      </div>
      <div class="fp-actions">
        <button type="button" id="fp-apply" class="fp-apply">적용</button>
        <a href="/" class="fp-reset">전체 초기화</a>
      </div>
    </div>

    {(types.length > 0 || cats.length > 0 || q) && (
      <div class="filter-active">
        {types.map((t) => (
          <a class="fa-pill" href={buildUrl({ type: types.filter((x) => x !== t).join(',') })}>{TYPE_LABELS[t]} ×</a>
        ))}
        {cats.map((c) => (
          <a class="fa-pill" href={buildUrl({ cat: cats.filter((x) => x !== c).join(',') })}>{c} ×</a>
        ))}
        {q && <a class="fa-pill" href={buildUrl({ q: '' })}>"{q}" ×</a>}
        <a href="/" class="fa-clear">전체 해제</a>
      </div>
    )}

    {error && <div class="empty">데이터를 불러오지 못했어요.</div>}
    {!error && list.length === 0 && <div class="empty">조건에 맞는 논문이 없어요.</div>}

    {!error && list.length > 0 && (
      <div class="list" id="list" data-sort={sort}>
        {list.map((p, i) => {
          const s = studyInfo(p.study_type);
          const country = (p.countries && p.countries[0]) ? countryName(p.countries[0]) : '';
          return (
            <article class="row" style={`animation-delay:${Math.min(i * 0.04, 0.5)}s`} data-cat={p.primary_category ? categoryKo(p.primary_category) : ''} data-stype={p.study_type || ''} data-cite={p.citation_count || 0} data-date={p.publication_date || p.publication_year || ''}>
              <div class="row-tags">
                <span class="tag" style={`color:${s.fg};background:${s.bg}`}>{s.label}</span>
                {p.primary_category && (() => { const fc = fieldColor(categoryKo(p.primary_category)); return <span class="tag-field" style={`color:${fc.fg};background:${fc.bg}`}>{categoryKo(p.primary_category)}</span>; })()}
                <i class="ti ti-chevron-right chev"></i>
              </div>
              <h2 class="row-title">{p.title_ko || p.title_en}</h2>
              <div class="row-meta">
                <span><i class="ti ti-quote" style="font-size:13px;vertical-align:-1px"></i> 인용 {(p.citation_count || 0).toLocaleString()}</span>
                {fmtDate(p) && <span><i class="ti ti-calendar" style="font-size:13px;vertical-align:-1px"></i> {fmtDate(p)}</span>}
                {country && <span>{country}</span>}
                <div class="trust">
                  <span style={`color:${s.strength >= 0.6 ? 'var(--accent)' : 'var(--ink-3)'}`}>신뢰도</span>
                  <div class="trust-bar"><div class="trust-fill" data-target={`${Math.round(s.strength * 100)}%`}></div></div>
                </div>
              </div>
              <div class="row-detail">
                <p class="row-abstract">{shortAbstract(p)}</p>
                <div class="row-actions">
                  <a class="btn-link" href={`/paper/${p.id}`}>자세히 보기</a>
                  <button type="button" class="btn-link bm" data-id={p.id}><i class="ti ti-bookmark"></i> 저장</button>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    )}

    {!error && totalPages > 1 && (
      <nav class="pager">
        {page > 1 && <a class="pager-btn" href={buildUrl({ page: page - 1 })}><i class="ti ti-chevron-left"></i> 이전</a>}
        <span class="pager-info">{page} / {totalPages}</span>
        {page < totalPages && <a class="pager-btn" href={buildUrl({ page: page + 1 })}>다음 <i class="ti ti-chevron-right"></i></a>}
      </nav>
    )}
  </main>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.0.0/dist/tabler-icons.min.css" />

  <script>
    // ── 개인화 배치: 추천순일 때, 이 기기에서 본 논문 취향으로 10칸당 [취향7 : 인기2 : 최신1] 재배치 ──
    (() => {
      const listEl = document.getElementById('list');
      if (!listEl || listEl.dataset.sort !== 'reco') return;
      let taste = null;
      try { taste = JSON.parse(localStorage.getItem('ra_taste') || 'null'); } catch {}
      if (!taste) return;
      const signals = Object.values(taste.cats || {}).reduce((a, b) => a + b, 0);
      if (signals < 3) return; // 취향 데이터가 너무 적으면 기본 추천 유지

      const rows = Array.from(listEl.querySelectorAll('.row'));
      if (rows.length < 10) return;
      const tScore = (r) => ((taste.cats || {})[r.dataset.cat] || 0) * 2 + ((taste.types || {})[r.dataset.stype] || 0);
      const byTaste = [...rows].sort((a, b) => tScore(b) - tScore(a));
      const byPop = [...rows].sort((a, b) => (+b.dataset.cite || 0) - (+a.dataset.cite || 0));
      const byNew = [...rows].sort((a, b) => String(b.dataset.date).localeCompare(String(a.dataset.date)));

      const used = new Set();
      const take = (arr) => { for (const r of arr) { if (!used.has(r)) { used.add(r); return r; } } return null; };
      const pattern = ['t', 't', 't', 'p', 't', 't', 't', 'n', 't', 'p']; // 취향7 인기2 최신1
      const out = [];
      for (let i = 0; out.length < rows.length; i++) {
        const k = pattern[i % 10];
        const r = k === 'p' ? (take(byPop) || take(byTaste) || take(byNew))
          : k === 'n' ? (take(byNew) || take(byTaste) || take(byPop))
          : (take(byTaste) || take(byPop) || take(byNew));
        if (!r) break;
        out.push(r);
      }
      out.forEach((r, i) => { r.style.animationDelay = `${Math.min(i * 0.04, 0.5)}s`; });
      listEl.append(...out);
    })();

    // 신뢰도 막대: 화면에 보이면 스르륵 차오름
    const fills = document.querySelectorAll('.trust-fill');
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach((en) => {
          if (en.isIntersecting) {
            en.target.style.width = en.target.getAttribute('data-target') || '0%';
            io.unobserve(en.target);
          }
        });
      }, { threshold: 0.3 });
      fills.forEach((f) => io.observe(f));
    } else {
      fills.forEach((f) => { f.style.width = f.getAttribute('data-target') || '0%'; });
    }

    // 카드 펼치기 (링크·버튼 클릭은 제외)
    document.querySelectorAll('.row').forEach((row) => {
      row.addEventListener('click', (e) => {
        if (e.target.closest('a, button')) return;
        row.classList.toggle('open');
      });
    });

    // 정렬 바꾸면 즉시 반영
    document.getElementById('sort-select')?.addEventListener('change', (e) => {
      const u = new URL(window.location.href);
      const v = e.target.value;
      if (v === 'reco') u.searchParams.delete('sort'); else u.searchParams.set('sort', v);
      u.searchParams.delete('page');
      window.location.href = u.toString();
    });

    // 필터 패널 열고닫기
    const panel = document.getElementById('filter-panel');
    document.getElementById('filter-toggle')?.addEventListener('click', () => {
      if (panel) panel.hidden = !panel.hidden;
    });

    // 패널 안 연구유형 칩: 여러 개 토글 ('전체'를 누르면 모두 해제)
    const selTypes = new Set((panel?.dataset.type || '').split(',').filter(Boolean));
    const typeBtns = panel ? Array.from(panel.querySelectorAll('.fp-type')) : [];
    function paintTypes() {
      typeBtns.forEach((b) => {
        const k = b.dataset.key;
        b.classList.toggle('on', k === 'all' ? selTypes.size === 0 : selTypes.has(k));
      });
    }
    typeBtns.forEach((b) => {
      b.addEventListener('click', () => {
        const k = b.dataset.key;
        if (k === 'all') selTypes.clear();
        else if (selTypes.has(k)) selTypes.delete(k);
        else selTypes.add(k);
        paintTypes();
      });
    });

    // 적용: 연구유형(여러 개) + 분야(여러 개)를 한 번에 반영
    document.getElementById('fp-apply')?.addEventListener('click', () => {
      const u = new URL(window.location.href);
      if (selTypes.size > 0) u.searchParams.set('type', Array.from(selTypes).join(',')); else u.searchParams.delete('type');
      const picked = Array.from(panel.querySelectorAll('.fp-grid input:checked')).map((i) => i.value);
      if (picked.length) u.searchParams.set('cat', picked.join(',')); else u.searchParams.delete('cat');
      u.searchParams.delete('page');
      window.location.href = u.toString();
    });

    // 한글 검색: 제출 전에 확장 용어를 만들어두고 이동 (한 번 만들면 캐시됨)
    const searchForm = document.querySelector('.search-box');
    searchForm?.addEventListener('submit', async (e) => {
      const input = searchForm.querySelector('input[name="q"]');
      const val = (input?.value || '').trim();
      if (!val || !/[가-힣]/.test(val)) return;
      e.preventDefault();
      try {
        await fetch('/api/expand-search', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ q: val }),
        });
      } catch {}
      searchForm.submit();
    });
  </script>
</Layout>
