---
import Layout from '../../layouts/Layout.astro';
import AuthBar from '../../components/AuthBar.astro';
import { supabase, STUDY_TYPE_LABELS, categoryKo, fieldColor, countryName } from '../../lib/supabase.js';

// 발표일 예쁘게: 2024-03-15 -> 2024.03.15
function fmtDate(d, year) {
  if (d) {
    const parts = String(d).split('-');
    if (parts.length === 3) return `${parts[0]}.${parts[1]}.${parts[2]}`;
    return String(d);
  }
  return year ? String(year) : '';
}

Astro.response.headers.set('Cache-Control', 'public, s-maxage=600, stale-while-revalidate=86400');

const { id } = Astro.params;

const { data: paper } = await supabase
  .from('papers')
  .select('*')
  .eq('id', id)
  .single();

// 논문이 없으면 404 (soft-404 방지: 리다이렉트 대신 정직한 404)
if (!paper) {
  return new Response(
    '<!DOCTYPE html><html lang="ko"><head><meta charset="utf-8"><meta name="robots" content="noindex"><title>논문을 찾을 수 없어요</title></head><body style="font-family:sans-serif;text-align:center;padding:80px 20px;background:#F4F4F5;color:#18181B"><h1 style="font-size:48px;color:#A1A1AA">404</h1><p>논문을 찾을 수 없어요. 삭제되었거나 주소가 바뀐 논문이에요.</p><a href="/" style="color:#3F6B5E">홈으로 가기</a></body></html>',
    { status: 404, headers: { 'Content-Type': 'text/html; charset=utf-8' } },
  );
}

// 같은 분야의 최신 논문 (내부 링크: 크롤러 탐색 + 방문자 체류)
let related = [];
if (paper.primary_category) {
  const { data: rel } = await supabase
    .from('papers')
    .select('id, title_ko, title_en, publication_date, publication_year')
    .eq('primary_category', paper.primary_category)
    .eq('is_retracted', false)
    .neq('id', paper.id)
    .order('publication_date', { ascending: false, nullsFirst: false })
    .limit(5);
  related = rel || [];
}

const s = STUDY_TYPE_LABELS[paper.study_type] || STUDY_TYPE_LABELS.unclassified;
const countries = (paper.countries || []).map(countryName).join(', ');
const authors = (paper.authors || []).map((a) => a.name).filter(Boolean).slice(0, 6).join(', ');

// 검색엔진용 구조화 데이터: 이 페이지가 '학술 논문'임을 알림 (한글 우선)
const canonicalPath = `/paper/${paper.id}`;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ScholarlyArticle',
  headline: paper.title_ko || paper.title_en,
  ...(paper.title_ko && paper.title_en && { alternativeHeadline: paper.title_en }),
  inLanguage: paper.title_ko ? 'ko' : 'en',
  url: `https://paper-aggregator.vercel.app${canonicalPath}`,
  ...(paper.doi && { sameAs: `https://doi.org/${paper.doi}` }),
  isAccessibleForFree: Boolean(paper.is_open_access),
  ...(authors && { author: (paper.authors || []).map((a) => ({ '@type': 'Person', name: a.name })) }),
  ...(paper.publication_date && { datePublished: paper.publication_date }),
  ...(paper.journal_name && { publisher: { '@type': 'Organization', name: paper.journal_name } }),
  ...((paper.abstract_ko || paper.abstract_en) && { abstract: paper.abstract_ko || paper.abstract_en }),
};
---
<Layout
  title={`${paper.title_ko || paper.title_en} — 연구 아카이브`}
  description={(paper.abstract_ko || paper.abstract_en || `${categoryKo(paper.primary_category) || ''} 분야 연구 논문`).slice(0, 150)}
  canonical={canonicalPath}
  jsonLd={jsonLd}
>
  <header class="topbar">
    <div class="wrap topbar-inner">
      <a class="brand" href="/">연구<span>아카이브</span><span class="dot"></span></a>
      <nav class="nav-links">
        <a href="/" class="on">논문</a>
        <a href="/board">게시판</a>
      </nav>
      <AuthBar />
    </div>
  </header>

  <main class="wrap" style="padding-top:24px;padding-bottom:60px">
    <div class="row-tags" style="margin-bottom:12px">
      <span class="tag" style={`color:${s.fg};background:${s.bg}`}>{s.label}</span>
      {paper.primary_category && (() => { const fc = fieldColor(categoryKo(paper.primary_category)); return <span class="tag-field" style={`color:${fc.fg};background:${fc.bg}`}>{categoryKo(paper.primary_category)}</span>; })()}
    </div>

    <h1 id="p-title" class="swap-el" style="font-size:24px;font-weight:600;line-height:1.35;letter-spacing:-0.02em;margin-bottom:8px">
      {paper.title_ko || paper.title_en}
    </h1>
    {paper.title_ko && paper.title_en && (
      <p id="p-subtitle" class="swap-el" style="font-size:14px;color:var(--ink-3);margin-bottom:16px">{paper.title_en}</p>
    )}

    <div class="row-meta" style="margin-bottom:24px;padding-bottom:20px;border-bottom:0.5px solid var(--line)">
      <span><i class="ti ti-quote" style="font-size:13px;vertical-align:-1px"></i> 인용 {paper.citation_count?.toLocaleString() || 0}</span>
      {fmtDate(paper.publication_date, paper.publication_year) && (
        <span><i class="ti ti-calendar" style="font-size:13px;vertical-align:-1px"></i> {fmtDate(paper.publication_date, paper.publication_year)}</span>
      )}
      {countries && <span>{countries}</span>}
      {paper.journal_name && <span>{paper.journal_name}</span>}
      {(paper.title_ko || paper.abstract_ko) && (
        <button type="button" id="lang-toggle" class="btn-link" style="cursor:pointer;font-family:inherit"><i class="ti ti-language"></i> 원문으로 보기</button>
      )}
      <button type="button" class="btn-link bm" data-id={paper.id}><i class="ti ti-bookmark"></i> 저장</button>
    </div>

    {authors && (
      <p style="font-size:13px;color:var(--ink-2);margin-bottom:20px"><strong style="font-weight:500">저자</strong> · {authors}</p>
    )}

    <section style="margin-bottom:28px">
      <h2 style="font-size:15px;font-weight:500;margin-bottom:10px">초록</h2>
      <p style="font-size:14px;color:var(--ink-2);line-height:1.75" id="abstract" class="swap-el">
        {paper.abstract_ko || paper.abstract_en || '초록이 제공되지 않는 논문입니다.'}
      </p>
    </section>

    {paper.fulltext_url && (
      <div class="row-actions" style="margin-bottom:8px">
        <a class="btn-link" href={paper.fulltext_url} target="_blank" rel="noopener">
          <i class="ti ti-external-link"></i> 원문 보기
        </a>
      </div>
    )}

    <div id="paper-data" data-id={paper.id} data-cat={paper.primary_category ? categoryKo(paper.primary_category) : ''} data-stype={paper.study_type || ''} hidden></div>
    <script type="application/json" id="paper-texts" set:html={JSON.stringify({ tk: paper.title_ko, te: paper.title_en, ak: paper.abstract_ko, ae: paper.abstract_en }).replace(/</g, '\\u003c')} />

    <script>
      import { supabase } from '../../lib/supabase.js';

      const pd = document.getElementById('paper-data');
      const pid = pd?.dataset.id;

      // ── 조회수 +1 (인기 신호) + 취향 기록 (개인화 신호, 이 기기에만 저장) ──
      if (pd && pid) {
        supabase.rpc('increment_view', { pid }).then(() => {}, () => {});
        try {
          const KEY = 'ra_taste';
          const t = JSON.parse(localStorage.getItem(KEY) || '{"cats":{},"types":{}}');
          const bump = (o, k) => { if (k) o[k] = Math.min((o[k] || 0) + 1, 50); };
          bump(t.cats, pd.dataset.cat);
          bump(t.types, pd.dataset.stype);
          localStorage.setItem(KEY, JSON.stringify(t));
        } catch {}
      }

      // ── 원문/한국어 전환 토글 (스르륵 페이드) ──
      const texts = document.getElementById('paper-texts');
      const lbtn = document.getElementById('lang-toggle');
      if (texts && lbtn) {
        const d = JSON.parse(texts.textContent);
        let en = false;
        const tEl = document.getElementById('p-title');
        const stEl = document.getElementById('p-subtitle');
        const abEl = document.getElementById('abstract');
        lbtn.addEventListener('click', () => {
          en = !en;
          [tEl, stEl, abEl].forEach((x) => x && x.classList.add('swapping'));
          setTimeout(() => {
            if (en) {
              if (tEl && d.te) tEl.textContent = d.te;
              if (stEl) stEl.hidden = true;
              if (abEl && d.ae) abEl.textContent = d.ae;
              lbtn.innerHTML = '<i class="ti ti-language"></i> 한국어로 보기';
            } else {
              if (tEl) tEl.textContent = d.tk || d.te;
              if (stEl) stEl.hidden = false;
              if (abEl) abEl.textContent = d.ak || d.ae || '';
              lbtn.innerHTML = '<i class="ti ti-language"></i> 원문으로 보기';
            }
            [tEl, stEl, abEl].forEach((x) => x && x.classList.remove('swapping'));
          }, 300);
        });
      }

    </script>

    {related.length > 0 && (
      <section style="margin-top:36px;padding-top:24px;border-top:0.5px solid var(--line)">
        <h2 style="font-size:15px;font-weight:600;margin-bottom:12px">{categoryKo(paper.primary_category)} 분야의 다른 최신 연구</h2>
        <ul style="list-style:none;display:flex;flex-direction:column;gap:10px">
          {related.map((r) => (
            <li>
              <a href={`/paper/${r.id}`} style="font-size:14px;color:var(--ink-2);line-height:1.5">
                <i class="ti ti-file-text" style="color:var(--ink-3)"></i> {r.title_ko || r.title_en}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </main>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.0.0/dist/tabler-icons.min.css" />
</Layout>
