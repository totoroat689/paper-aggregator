---
import Layout from '../layouts/Layout.astro';
import AuthBar from '../components/AuthBar.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: '연구 아카이브 소개',
  description: '전 세계 최신 실증 연구 논문을 한국어로 모아 보는 연구 아카이브를 소개합니다.',
};
---
<Layout
  title="소개 — 연구 아카이브"
  description="연구 아카이브는 전 세계 학술 데이터베이스에서 매일 최신 실증 연구를 수집해 한국어로 보여주는 서비스입니다."
  canonical="/about"
  jsonLd={jsonLd}
>
  <header class="topbar">
    <div class="wrap topbar-inner">
      <a href="/" class="brand">연구<span>아카이브</span><span class="dot"></span></a>
      <nav class="nav-links">
        <a href="/">논문</a>
        <a href="/board">게시판</a>
      </nav>
      <AuthBar />
    </div>
  </header>

  <main class="wrap" style="padding-top:28px;padding-bottom:40px;max-width:720px">
    <h1 style="font-size:22px;font-weight:600;margin-bottom:20px">연구 아카이브 소개</h1>

    <div class="post-view">
      <p style="font-size:15px;line-height:1.8;color:var(--ink-2);margin-bottom:18px">
        <strong>연구 아카이브</strong>는 전 세계에서 매일 쏟아지는 학술 논문 가운데
        <strong>실증 연구</strong>(실험연구·메타분석·관찰연구 등)를 자동으로 수집해,
        한국어 화면에서 한눈에 살펴볼 수 있게 만든 서비스입니다.
        연구 방법의 신뢰 수준을 함께 표시해, 근거가 튼튼한 연구를 먼저 볼 수 있도록 돕습니다.
      </p>

      <h2 style="font-size:15px;font-weight:600;margin:22px 0 8px">연구유형과 신뢰도 표시</h2>
      <p style="font-size:14px;line-height:1.8;color:var(--ink-2)">
        논문의 초록을 분석해 메타분석·무작위대조시험(RCT)·실험연구·관찰연구·리뷰 등
        연구유형을 분류하고, 일반적으로 통용되는 근거 수준에 따라 신뢰도 게이지를 표시합니다.
        분류는 자동화된 방식이라 완벽하지 않을 수 있으며, 중요한 판단에는 반드시 원문을 확인해 주세요.
      </p>

      <h2 style="font-size:15px;font-weight:600;margin:22px 0 8px">문의</h2>
      <p style="font-size:14px;line-height:1.8;color:var(--ink-2)">
        서비스에 대한 의견이나 오류 제보는 <a href="/board" style="text-decoration:underline">게시판</a>에 남겨주세요.
      </p>
    </div>
  </main>
</Layout>
