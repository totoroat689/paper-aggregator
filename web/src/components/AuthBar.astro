---
// 로그인 영역: 비로그인 = [구글 로그인] 버튼, 로그인 = [프로필 사진+이름 ▾] 드롭다운
// 페이지의 북마크 버튼(.bm[data-id]) 동작도 여기서 함께 처리합니다.
---
<div class="auth-area">
  <button type="button" id="login-btn" class="auth-btn" hidden>
    <i class="ti ti-brand-google"></i> 로그인
  </button>
  <div id="user-box" class="user-box" hidden>
    <button type="button" id="user-toggle" class="user-toggle">
      <img id="user-avatar" class="user-avatar" alt="" referrerpolicy="no-referrer" hidden />
      <span id="user-initial" class="user-initial" hidden></span>
      <span id="user-name"></span>
      <i class="ti ti-chevron-down" style="font-size:14px;color:var(--ink-3)"></i>
    </button>
    <div id="user-dropdown" class="user-dropdown" hidden>
      <div class="ud-email" id="user-email"></div>
      <a href="/profile" class="ud-item"><i class="ti ti-user"></i> 내 정보</a>
      <a href="/bookmarks" class="ud-item"><i class="ti ti-bookmark"></i> 북마크</a>
      <button type="button" id="logout-btn" class="ud-item"><i class="ti ti-logout"></i> 로그아웃</button>
    </div>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabase.js';

  const loginBtn = document.getElementById('login-btn');
  const userBox = document.getElementById('user-box');
  const dropdown = document.getElementById('user-dropdown');

  async function login() {
    await supabase.auth.signInWithOAuth({
      provider: 'google',
      options: { redirectTo: window.location.href },
    });
  }
  loginBtn?.addEventListener('click', login);

  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.href = '/';
  });

  // 드롭다운 열고닫기 (바깥 클릭하면 닫힘)
  document.getElementById('user-toggle')?.addEventListener('click', (e) => {
    e.stopPropagation();
    if (dropdown) dropdown.hidden = !dropdown.hidden;
  });
  document.addEventListener('click', (e) => {
    if (dropdown && !dropdown.hidden && !e.target.closest('.user-box')) dropdown.hidden = true;
  });

  // 프로필(닉네임)이 없으면 자동 생성 — 게시판에서 쓸 이름
  async function ensureProfile(session) {
    try {
      const uid = session.user.id;
      const { data } = await supabase.from('profiles').select('nickname').eq('id', uid).maybeSingle();
      if (data) return data.nickname;
      const base = ((session.user.email || 'user').split('@')[0] || 'user').slice(0, 20);
      let nick = base;
      for (let i = 0; i < 3; i++) {
        const { error } = await supabase.from('profiles').insert({ id: uid, nickname: nick });
        if (!error) return nick;
        if (error.code === '23505' && (error.message || '').includes('nickname')) {
          nick = base.slice(0, 15) + Math.floor(1000 + Math.random() * 9000);
          continue;
        }
        return nick; // 이미 있음(동시 생성) 또는 표 미생성 — 조용히 통과
      }
      return nick;
    } catch { return null; }
  }

  async function render(session) {
    if (!session) {
      if (loginBtn) loginBtn.hidden = false;
      if (userBox) userBox.hidden = true;
      return;
    }
    if (loginBtn) loginBtn.hidden = true;
    if (userBox) userBox.hidden = false;

    const meta = session.user.user_metadata || {};
    const nickname = await ensureProfile(session);
    const display = nickname || meta.full_name || meta.name || (session.user.email || '').split('@')[0];

    const nameEl = document.getElementById('user-name');
    if (nameEl) nameEl.textContent = display;
    const emailEl = document.getElementById('user-email');
    if (emailEl) emailEl.textContent = session.user.email || '';

    const av = document.getElementById('user-avatar');
    const ini = document.getElementById('user-initial');
    if (meta.avatar_url && av) {
      av.src = meta.avatar_url;
      av.hidden = false;
      if (ini) ini.hidden = true;
    } else if (ini) {
      ini.textContent = (display || '?').slice(0, 1).toUpperCase();
      ini.hidden = false;
    }
  }

  // ── 북마크 버튼 처리 ─────────────────────────────────────────
  const bmButtons = Array.from(document.querySelectorAll('.bm[data-id]'));

  function paintBookmark(btn, saved) {
    btn.classList.toggle('on', saved);
    btn.innerHTML = saved
      ? '<i class="ti ti-bookmark-filled"></i> 저장됨'
      : '<i class="ti ti-bookmark"></i> 저장';
  }

  async function markSaved(session) {
    if (!session || bmButtons.length === 0) return;
    const ids = bmButtons.map((b) => b.dataset.id);
    const { data } = await supabase.from('bookmarks').select('paper_id').in('paper_id', ids);
    const saved = new Set((data || []).map((r) => r.paper_id));
    bmButtons.forEach((b) => paintBookmark(b, saved.has(b.dataset.id)));
  }

  bmButtons.forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      e.stopPropagation();
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        if (confirm('북마크는 로그인 후 이용할 수 있어요. 구글로 로그인할까요?')) login();
        return;
      }
      const id = btn.dataset.id;
      const isOn = btn.classList.contains('on');
      paintBookmark(btn, !isOn);
      if (isOn) {
        const { error } = await supabase.from('bookmarks').delete().eq('paper_id', id);
        if (error) paintBookmark(btn, true);
      } else {
        const { error } = await supabase.from('bookmarks').insert({ paper_id: id });
        if (error && error.code !== '23505') paintBookmark(btn, false);
      }
    });
  });

  supabase.auth.getSession().then(({ data: { session } }) => {
    render(session);
    markSaved(session);
  });
  supabase.auth.onAuthStateChange((_evt, session) => render(session));
</script>
